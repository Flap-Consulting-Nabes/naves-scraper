# ── Required — must be set before starting ────────────────────────────────
DASHBOARD_PASSWORD=          # Password to access the dashboard

# API_SECRET_KEY is auto-generated by install.sh — leave blank here
API_SECRET_KEY=

# ── Webflow CMS (leave blank to skip) ────────────────────────────────────
# Token needs scopes: cms:read, cms:write, assets:read, assets:write, sites:read
# WEBFLOW_TOKEN=
# WEBFLOW_COLLECTION_ID=
# WEBFLOW_SITE_ID=

# ── Cloudinary (intermediate image host) ──────────────────────────────────
# Staging bucket so Webflow CDN re-hosts images with slug-based filenames.
# Used as fallback when WEBFLOW_TOKEN lacks assets:read/assets:write scopes.
# Free tier (25 GB) is plenty — assets are deleted after Webflow copies them.
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# ── Optional — all have working defaults ──────────────────────────────────
# DB_PATH=naves.db
# MAX_PAGES=0              # 0 = no page limit
# MIN_SURFACE_M2=1000      # Filter listings below 1000m2
# DOWNLOAD_IMAGES=true
# IMAGES_DIR=images
# API_BASE_URL=http://localhost:8000
# CORS_ORIGINS=http://localhost:3000,https://your-domain.com
