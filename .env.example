# ── Scraper ────────────────────────────────────────────────────────────────
DB_PATH=naves.db
MAX_PAGES=0                  # 0 = sin límite de páginas
MIN_SURFACE_M2=1000          # Filtrar naves < 1000m²
DOWNLOAD_IMAGES=true         # Descargar imágenes localmente
IMAGES_DIR=images
# PROXY_SERVER=http://user:pass@host:port

# ── Webflow CMS ────────────────────────────────────────────────────────────
# Token needs scopes: cms:read, cms:write, assets:read, assets:write, sites:read
WEBFLOW_TOKEN=               # Token de API de Webflow (Settings → Integrations → API token)
WEBFLOW_COLLECTION_ID=       # ID de la colección de Webflow
# Optional: pin the site id to skip a /sites round-trip and disambiguate
# multi-site workspaces. Required by scripts/migrate_images.py Phase G.
WEBFLOW_SITE_ID=

# ── Cloudinary (intermediate image host) ──────────────────────────────────
# Staging bucket so Webflow's CDN re-hosts images with slug-based filenames
# instead of UUIDs. Used automatically as fallback when WEBFLOW_TOKEN lacks
# assets:read/assets:write. Dashboard → Settings → API Keys.
# Each uploaded asset is deleted from Cloudinary once Webflow has copied it
# to its own CDN, so the free tier (25 GB / 25k transformations) is plenty.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── API / Microservicio ────────────────────────────────────────────────────
# Dejar vacío: install.sh lo genera automáticamente con secrets.token_hex(32)
API_SECRET_KEY=

# ── Dashboard ─────────────────────────────────────────────────────────────
DASHBOARD_PASSWORD=          # Contraseña para acceder al dashboard (obligatorio)
API_BASE_URL=http://localhost:8000

# ── CORS ──────────────────────────────────────────────────────────────────
# Origenes permitidos (separados por coma). Por defecto: http://localhost:3000
# CORS_ORIGINS=http://localhost:3000,https://tu-dominio.com
